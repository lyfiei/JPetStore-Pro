spring.application.name=JPetStore

# 数据库配置
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.datasource.url=jdbc:mysql://127.0.0.1:3306/jpetstore?useSSL=false&serverTimezone=UTC&characterEncoding=utf-8&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=你的数据库密码

# Thymeleaf configuration
spring.thymeleaf.prefix=classpath:/templates/
spring.thymeleaf.suffix=.html
spring.thymeleaf.mode=HTML
spring.thymeleaf.encoding=UTF-8
spring.thymeleaf.cache=false

# MyBatis configuration
mybatis.mapper-locations=classpath:mapper/*.xml
mybatis.type-aliases-package=com.csu.jpetstore.domain
mybatis.configuration.map-underscore-to-camel-case=true

# JWT
jwt.secret=JPetStore2024SecretKey!@#$
jwt.expiration=86400000

# GitHub OAuth（可选，不填则 GitHub 登录不可用）
github.oauth.client-id=
github.oauth.client-secret=
github.oauth.redirect-uri=

# Frontend URL（OAuth 回调用，可选）
app.frontend-url=
