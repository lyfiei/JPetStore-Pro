<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.csu.jpetstore.mapper.CategoryMapper">

    <select id="getCategoryList" resultType="com.csu.jpetstore.domain.Category">
        SELECT
            CATID AS categoryId,
            NAME,
            DESCN AS description
        FROM CATEGORY
    </select>

    <select id="getCategory" parameterType="string" resultType="com.csu.jpetstore.domain.Category">
        SELECT
            CATID AS categoryId,
            NAME,
            DESCN AS description
        FROM CATEGORY
        WHERE CATID = #{categoryId}
    </select>

</mapper>