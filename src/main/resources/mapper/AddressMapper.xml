<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.csu.jpetstore.mapper.AddressMapper">

    <resultMap id="addressResultMap" type="com.csu.jpetstore.domain.Address">
        <id property="addressId" column="address_id"/>
        <result property="username" column="user_id"/>
        <result property="firstName" column="first_name"/>
        <result property="lastName" column="last_name"/>
        <result property="address1" column="address1"/>
        <result property="address2" column="address2"/>
        <result property="city" column="city"/>
        <result property="state" column="state"/>
        <result property="zip" column="zip"/>
        <result property="country" column="country"/>
    </resultMap>

    <select id="getAddressListByUsername" resultMap="addressResultMap">
        SELECT * FROM address WHERE user_id = #{username} ORDER BY address_id DESC
    </select>

    <select id="getAddressById" resultMap="addressResultMap">
        SELECT * FROM address WHERE address_id = #{addressId}
    </select>

    <insert id="insertAddress" parameterType="com.csu.jpetstore.domain.Address" useGeneratedKeys="true" keyProperty="addressId">
        INSERT INTO address (user_id, first_name, last_name, address1, address2,
                            city, state, zip, country)
        VALUES (#{username}, #{firstName}, #{lastName}, #{address1}, #{address2},
                #{city}, #{state}, #{zip}, #{country})
    </insert>

    <update id="updateAddress">
        UPDATE address
        SET first_name = #{firstName},
            last_name = #{lastName},
            address1 = #{address1},
            address2 = #{address2},
            city = #{city},
            state = #{state},
            zip = #{zip},
            country = #{country}
        WHERE address_id = #{addressId}
    </update>

    <delete id="deleteAddress">
        DELETE FROM address WHERE address_id = #{addressId}
    </delete>

</mapper>
